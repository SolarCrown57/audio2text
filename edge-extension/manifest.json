{
  "manifest_version": 3,
  "name": "Audio2Text - 实时字幕",
  "version": "1.0.0",
  "description": "捕获浏览器标签页音频并实时转换为字幕",
  "permissions": [
    "tabCapture",
    "activeTab",
    "scripting",
    "offscreen"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
